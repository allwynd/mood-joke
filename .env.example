# ─── Server ────────────────────────────────────────────────────────────────
PORT=3000

# ─── AI Agent ──────────────────────────────────────────────────────────────
# Required: your Anthropic API key
ANTHROPIC_API_KEY=YOUR_KEY
ANTHROPIC_MODEL=YOUR_MODEL

# ─── Joke Store ─────────────────────────────────────────────────────────────
# "local"  → reads from jokes.json (default, no extra setup)
# "vector" → queries a vector database (configure section below)
STORE=local

# Path to the jokes JSON file (used when STORE=local)
# Defaults to ./jokes.json if not set
#JOKES_FILE=./jokes.json

# ─── Vector DB (only needed when STORE=vector) ──────────────────────────────
# Which vector DB to use: "pinecone" | "qdrant"
VECTOR_PROVIDER=pinecone

# Name of the index / collection in your vector DB
VECTOR_INDEX_NAME=mood-jokes

# ── Pinecone ────────────────────────────────────────────────────────────────
PINECONE_API_KEY=

# ── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_URL=YOUR_ENDPOINT

# ─── Embedding provider (used by indexJokes.js and VectorStore) ─────────────
OPENAI_API_KEY=
